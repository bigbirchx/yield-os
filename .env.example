# App
APP_ENV=development
API_PORT=8000
WEB_PORT=3000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=yield_cockpit
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Required paid sources
# Velo: contact sales at https://velo.xyz — needed for all derivatives data
VELO_API_KEY=
# DeFiLlama: free tier works without a key; Pro key lifts rate limits
DEFILLAMA_API_KEY=

# Protocol risk connectors — all public APIs, no keys required
# Aave:   https://api.v3.aave.com/graphql  (official Aave API, no key)
# Morpho: https://blue-api.morpho.org/graphql  (public)
# Kamino: https://api.kamino.finance  (public)

# Optional AI/dev
ANTHROPIC_API_KEY=

# Optional later — price feed for USD-normalizing native borrow/supply caps
CMC_API_KEY=
COINGECKO_API_KEY=
STAKING_REWARDS_API_KEY=

# Logging
LOG_LEVEL=INFO
